# Copy to .env and adjust for your machine:
#   cp .env.example .env

# Network: nile | mainnet
NETWORK=nile

# java-tron release tag (downloaded at build time)
# Nile:    https://github.com/tron-nile-testnet/nile-testnet/releases
# Mainnet: https://github.com/tronprotocol/java-tron/releases
JAVA_TRON_VERSION=GreatVoyage-Nile-v4.8.2-PQ1-build1

# JVM / container memory
JVM_HEAP_GB=24
MEM_LIMIT=32g

# Docker container names (docker ps / docker exec)
KAFKA_CONTAINER_NAME=kafka
TRON_CONTAINER_NAME=tron-node

# Docker bridge network shared by kafka + tron (and other stacks on the same host)
DOCKER_NETWORK_NAME=tronsave

# Host paths bind-mounted into containers (absolute paths recommended on Linux servers)
# Tron: folder must contain database/ and index/ (java-tron output-directory layout)
TRON_DATA_PATH=./data/tron
# Kafka: broker log directory
KAFKA_DATA_PATH=./data/kafka

# Example — reuse an existing snapshot / node data:
# TRON_DATA_PATH=/home/user/tron/output-directory
# KAFKA_DATA_PATH=/home/user/kafka-data

# Service ports (host = container)
HTTP_PORT=8090
GRPC_PORT=50051
JSONRPC_PORT=8545
P2P_PORT=18888

# Kafka: KAFKA_PORT = host access, KAFKA_INTERNAL_PORT = tron -> kafka inside Docker network
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=19092
KAFKA_ADVERTISED_HOST=localhost

# Message retention (default: 7 days)
KAFKA_LOG_RETENTION_MS=604800000

# Kafka event plugin (java-tron 4.8.2: event.subscribe.enable = true)
EVENT_PLUGIN_ENABLED=true
EVENT_START_SYNC_BLOCK_NUM=0

# Event filters (comma-separated lists). Leave empty to subscribe to ALL events.
# EVENT_CONTRACT_ADDRESS: only emit events from these contract addresses (base58).
# EVENT_CONTRACT_TOPIC:   only emit events matching these topic hashes.
# Example: EVENT_CONTRACT_ADDRESS=TXYZ...,TABC...
EVENT_CONTRACT_ADDRESS=
EVENT_CONTRACT_TOPIC=

# Lite FullNode: set LITE_NODE=true and put a lite snapshot under TRON_DATA_PATH (see README)
LITE_NODE=false
LITE_OPEN_HISTORY=false
